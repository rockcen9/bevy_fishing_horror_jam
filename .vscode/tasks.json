{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Cargo Run",
            "type": "shell",
            "command": "cargo",
            "args": [
                "run",
                "--bin",
                "bevy_game",
                "--features",
                " dev_native, ",
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            // "options": {
            //     "env": {
            //         "RUST_BACKTRACE": "full"
            //     }
            // },
            "detail": "Run cargo run to build and execute the project."
        },
        {
            "label": "Cargo Check",
            "type": "shell",
            "command": "cargo",
            "args": [
                "check",
                "--bin",
                "bevy_game",
                "--features",
                "dev_native",
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "detail": "Run cargo check to check the project without building it."
        },
        {
            "label": "Cargo Fix",
            "type": "shell",
            "command": "cargo",
            "args": [
                "fix",
                "--features",
                "dev_native",
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "detail": "Run cargo run to build and execute the project."
        },
        {
            "label": "Hot Reload",
            "type": "shell",
            "command": "dx",
            "args": [
                "serve",
                "--hot-patch",
                "--features",
                "dev_native"
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "options": {
                "env": {
                    "BEVY_ASSET_ROOT": "."
                }
            },
            "detail": "Run dx serve to hot reload the project."
        }
    ]
}