{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug executable 'bevy_game'",
            "cargo": {
                "args": [
                    "build",
                    "--bin=bevy_game",
                    "--package=bevy_game",
                    "--features",
                    "dev",
                    "--profile",
                    "lldb"
                ],
                "filter": {
                    "name": "bevy_game",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}",
            "env": {
                "CARGO_MANIFEST_DIR": "${workspaceFolder}",
                "DYLD_FALLBACK_LIBRARY_PATH": "${env:HOME}/.rustup/toolchains/stable-aarch64-apple-darwin/lib:${workspaceFolder}/target/debug",
            }
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit tests in executable 'bevy_game'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--bin=bevy_game",
                    "--package=bevy_game"
                ],
                "filter": {
                    "name": "bevy_game",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        }
    ]
}
